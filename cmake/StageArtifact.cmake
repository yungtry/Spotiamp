if(NOT DEFINED PROJECT_ROOT)
  message(FATAL_ERROR "PROJECT_ROOT is required")
endif()

if(NOT DEFINED DIST_DIR)
  message(FATAL_ERROR "DIST_DIR is required")
endif()

file(TO_CMAKE_PATH "${PROJECT_ROOT}" PROJECT_ROOT)
file(TO_CMAKE_PATH "${DIST_DIR}" DIST_DIR)
if(DEFINED BUNDLE)
  file(TO_CMAKE_PATH "${BUNDLE}" BUNDLE)
endif()
if(DEFINED BINARY)
  file(TO_CMAKE_PATH "${BINARY}" BINARY)
endif()

if(EXISTS "${DIST_DIR}")
  file(REMOVE_RECURSE "${DIST_DIR}")
endif()
file(MAKE_DIRECTORY "${DIST_DIR}")

if(DEFINED BUNDLE AND NOT "${BUNDLE}" STREQUAL "" AND EXISTS "${PROJECT_ROOT}/${BUNDLE}")
  file(COPY "${PROJECT_ROOT}/${BUNDLE}" DESTINATION "${DIST_DIR}")
else()
  if(NOT DEFINED BINARY OR "${BINARY}" STREQUAL "")
    message(FATAL_ERROR "BINARY is required when BUNDLE is not used")
  endif()
  if(NOT DEFINED EXECUTABLE OR "${EXECUTABLE}" STREQUAL "")
    message(FATAL_ERROR "EXECUTABLE is required when BUNDLE is not used")
  endif()

  file(COPY "${PROJECT_ROOT}/${BINARY}" DESTINATION "${DIST_DIR}")
  get_filename_component(COPIED_NAME "${BINARY}" NAME)
  if(NOT COPIED_NAME STREQUAL EXECUTABLE)
    file(RENAME "${DIST_DIR}/${COPIED_NAME}" "${DIST_DIR}/${EXECUTABLE}")
  endif()
  file(COPY "${PROJECT_ROOT}/assets" DESTINATION "${DIST_DIR}")
endif()

file(COPY "${PROJECT_ROOT}/LICENSE" DESTINATION "${DIST_DIR}")
